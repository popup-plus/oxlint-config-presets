{
  "name": "oxlint-config-presets",
  "version": "0.1.0",
  "description": "Oxlint configurations ported from popular ESLint styleguides",
  "license": "MIT",
  "packageManager": "pnpm@10.29.3",
  "type": "module",
  "publishConfig": {
    "directory": "configs"
  },
  "exports": {
    "./airbnb": "./airbnb/index.json",
    "./airbnb/base": "./airbnb/base.json",
    "./airbnb/hooks": "./airbnb/hooks.json",
    "./airbnb/legacy": "./airbnb/legacy.json",
    "./airbnb/whitespace": "./airbnb/whitespace.json",
    "./standard": "./standard/index.json",
    "./google": "./google/index.json",
    "./eslint-js/recommended": "./eslint-js/recommended.json",
    "./eslint-js/all": "./eslint-js/all.json",
    "./xo": "./xo/index.json",
    "./problems": "./problems/index.json",
    "./hardcore": "./hardcore/index.json",
    "./wikimedia": "./wikimedia/index.json",
    "./eslint-team": "./eslint-team/index.json",
    "./eslint-team/base": "./eslint-team/base.json",
    "./alloy": "./alloy/index.json",
    "./alloy/react": "./alloy/react.json",
    "./alloy/typescript": "./alloy/typescript.json",
    "./prettier": "./prettier/index.json",
    "./antfu": "./antfu/index.json",
    "./typescript-eslint/recommended": "./typescript-eslint/recommended.json",
    "./typescript-eslint/recommended-type-checked": "./typescript-eslint/recommended-type-checked.json",
    "./typescript-eslint/strict": "./typescript-eslint/strict.json",
    "./typescript-eslint/strict-type-checked": "./typescript-eslint/strict-type-checked.json",
    "./typescript-eslint/stylistic": "./typescript-eslint/stylistic.json",
    "./typescript-eslint/stylistic-type-checked": "./typescript-eslint/stylistic-type-checked.json",
    "./typescript-eslint/all": "./typescript-eslint/all.json"
  },
  "scripts": {
    "generate": "tsx scripts/generate.ts",
    "prepack": "tsx scripts/prepack.ts",
    "test": "node --import tsx/esm --test tests/*.test.ts"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@eslint/js": "^10.0.1",
    "@oxlint/migrate": "^1.57.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^8.57.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-alloy": "^5.1.2",
    "eslint-config-eslint": "^14.0.0",
    "eslint-config-google": "^0.14.0",
    "eslint-config-hardcore": "^49.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-problems": "^9.0.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-config-wikimedia": "^0.32.3",
    "eslint-config-xo": "^0.51.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^4.6.2",
    "oxlint": "1.57.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
