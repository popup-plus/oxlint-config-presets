{
  "name": "oxlint-config-presets",
  "version": "0.1.4",
  "description": "Oxlint configurations ported from popular ESLint styleguides",
  "keywords": [
    "config",
    "eslint",
    "lint",
    "oxlint",
    "styleguide"
  ],
  "homepage": "https://github.com/popup-plus/oxlint-config-presets#readme",
  "bugs": {
    "url": "https://github.com/popup-plus/oxlint-config-presets/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/popup-plus/oxlint-config-presets.git"
  },
  "type": "module",
  "publishConfig": {
    "directory": "configs"
  },
  "scripts": {
    "before-commit": "pnpm generate && pnpm test && pnpm oxlint",
    "fmt": "oxfmt",
    "generate": "rm -rf configs && node --import tsx/esm scripts/generate.ts && oxfmt",
    "oxlint": "oxlint",
    "prepack": "node --import tsx/esm scripts/prepack.ts",
    "test": "node --import tsx/esm --test tests/*.test.ts"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@eslint/js": "^10.0.1",
    "@oxlint/migrate": "^1.58.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^8.57.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-alloy": "^5.1.2",
    "eslint-config-eslint": "^14.0.0",
    "eslint-config-google": "^0.14.0",
    "eslint-config-hardcore": "^49.0.0",
    "eslint-config-next": "^16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-problems": "^9.0.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-config-wikimedia": "^0.32.3",
    "eslint-config-xo": "^0.51.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^4.6.2",
    "next": "16.2.1",
    "oxfmt": "^0.43.0",
    "oxlint": "1.58.0",
    "oxlint-tsgolint": "^0.18.1",
    "tsx": "^4.19.3",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.29.3"
}
